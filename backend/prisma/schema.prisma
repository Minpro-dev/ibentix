// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
}

enum Role {
  ATTENDEE
  ORGANIZER
}

enum OrderStatus {
  pending
  paid
  skipped
}

model User {
  userId       String    @id @default(uuid())
  firstName    String    @db.VarChar(35)
  lastName     String    @db.VarChar(35)
  email        String    @unique @db.VarChar(100)
  phone        String    @unique @db.VarChar(15)
  gender       Gender
  countryId    String
  role         Role
  password     String    @db.VarChar(100)
  avatar       String
  pointsId     BigInt
  referralCode String    @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  country          Country           @relation(fields: [countryId], references: [countryId])
  points           Point[]
  tickets          Ticket[]
  orders           Order[]
  reviews          Review[]
  events           Event[]           @relation("OrganizerEvents")
  organizerProfile OrganizerProfile?
  referralCoupons  ReferralCoupon[]  @relation("UserCoupons")
  referredCoupons  ReferralCoupon[]  @relation("ReferralOwner")
  wishlists        Wishlist[]

  @@map("users")
}

model Country {
  countryId   String    @id @default(uuid())
  countryName String    @db.VarChar(75)
  countryCode String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  users User[]

  @@map("countries")
}

model Point {
  pointId     String   @id @default(uuid())
  userId      String
  pointAmount Int
  validFrom   DateTime
  validUntil  DateTime

  user User @relation(fields: [userId], references: [userId])

  @@map("points")
}

model Ticket {
  ticketId      String    @id @default(uuid())
  orderId       String
  userId        String
  attendeeName  String
  attendeeEmail String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  user  User  @relation(fields: [userId], references: [userId])
  order Order @relation(fields: [orderId], references: [orderId])

  @@map("tickets")
}

model Order {
  orderId        String      @id @default(uuid())
  userId         String
  eventId        String
  orderNumber    String      @db.VarChar(8)
  quantity       Int
  unitPrice      Decimal
  subtotal       Decimal
  discountAmount Decimal
  totalAmount    Decimal
  couponId       String?
  status         OrderStatus
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  user  User  @relation(fields: [userId], references: [userId])
  event Event @relation(fields: [eventId], references: [eventId])

  tickets Ticket[]
  review  Review?

  @@map("orders")
}

model Event {
  eventId      String    @id @default(uuid())
  organizerId  String
  categoryId   String
  name         String    @db.VarChar(100)
  description  String?
  thumbnailUrl String?
  locationName String?
  address      String?
  city         String?
  startDate    DateTime
  endDate      DateTime
  couponId     String?
  price        Decimal
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  organizer User          @relation("OrganizerEvents", fields: [organizerId], references: [userId])
  orders    Order[]
  reviews   Review[]
  category  EventCategory @relation(fields: [categoryId], references: [categoryId])
  coupons   EventCoupon[]
  wishlists Wishlist[]

  @@map("events")
}

model EventCoupon {
  couponId       String    @id @default(uuid())
  couponCode     String    @db.VarChar(5)
  eventId        String
  validFrom      DateTime
  validUntil     DateTime
  discountAmount Decimal
  usedAt         DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  event Event @relation(fields: [eventId], references: [eventId])

  @@map("eventCoupons")
}

model EventCategory {
  categoryId   String    @id @default(uuid())
  eventId      String
  categoryName String    @db.VarChar(30)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  events Event[]

  @@map("eventCategories")
}

model Review {
  reviewId    String    @id @default(uuid())
  orderId     String    @unique
  eventId     String
  userId      String
  rating      Int // 1 - 5
  description String?
  isAnonymous Boolean
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user  User  @relation(fields: [userId], references: [userId])
  event Event @relation(fields: [eventId], references: [eventId])
  order Order @relation(fields: [orderId], references: [orderId])

  @@map("reviews")
}

model ReferralCoupon {
  referralId     String    @id @default(uuid())
  couponCode     String    @unique @db.VarChar(5)
  userId         String
  referralCodeBy String
  discountAmount Decimal
  usedAt         DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // RELATIONS
  user       User @relation("UserCoupons", fields: [userId], references: [userId])
  referredBy User @relation("ReferralOwner", fields: [referralCodeBy], references: [userId])

  @@map("referralCoupons")
}

model OrganizerProfile {
  organizerId String    @id @default(uuid())
  userId      String    @unique
  name        String    @db.VarChar(30)
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // RELATION (1-1)
  user User @relation(fields: [userId], references: [userId])

  @@map("organizerProfile")
}

model Wishlist {
  id        String    @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // RELATIONS
  user  User  @relation(fields: [userId], references: [userId])
  event Event @relation(fields: [eventId], references: [eventId])

  @@unique([userId, eventId]) // supaya tidak duplicate wishlist
  @@map("wishlist")
}

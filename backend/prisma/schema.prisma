// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
}

enum Role {
  ATTENDEE
  ORGANIZER
}

enum PaymentStatus {
  WAITING_FOR_PAYMENT
  WAITING_FOR_ADMIN_CONFIRMATION
  DONE
  REJECTED
  EXPIRED
  CANCELED
}

model User {
  userId                String    @id @default(uuid())
  firstName             String    @db.VarChar(35)
  lastName              String    @db.VarChar(35)
  email                 String    @unique @db.VarChar(100)
  phone                 String    @unique @db.VarChar(15)
  gender                Gender
  countryId             String
  role                  Role
  password              String    @db.VarChar(100)
  avatar                String?
  isVerified            Boolean   @default(false)
  otp                   String?
  otpExpiresAt          DateTime?
  pointsId              BigInt
  generatedReferralCode String?
  referralCode          String    @unique
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  country Country @relation(fields: [countryId], references: [countryId])
  events  Event[] @relation("OrganizerEvents")

  points           Point[]
  tickets          Ticket[]
  orders           Order[]
  reviews          Review[]
  wishlists        Wishlist[]
  organizerProfile OrganizerProfile?

  referralCoupons ReferralCoupon[] @relation("UserCoupons")
  referredCoupons ReferralCoupon[] @relation("ReferralOwner")

  @@map("users")
}

model Country {
  countryId   String    @id @default(uuid())
  countryName String    @db.VarChar(75)
  countryCode String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  users User[]

  @@map("countries")
}

model Point {
  pointId     String   @id @default(uuid())
  userId      String
  pointAmount Int
  validFrom   DateTime
  validUntil  DateTime
  isActive    Boolean

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [userId])

  @@map("points")
}

model Ticket {
  ticketId      String    @id @default(uuid())
  orderId       String
  userId        String
  attendeeName  String
  attendeeEmail String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  user  User  @relation(fields: [userId], references: [userId])
  order Order @relation(fields: [orderId], references: [orderId])

  @@map("tickets")
}

model Order {
  orderId String @id @default(uuid())

  invoiceNumber String @unique

  userId  String
  eventId String

  orderNumber    String
  ticketQuantity Int

  unitPrice      Decimal
  subtotal       Decimal
  discountAmount Decimal
  pointsUsed     Decimal
  totalAmount    Decimal

  eventCouponId    String?
  appCouponId      String?
  referralCouponId String?

  paymentId String? @unique

  expireAt DateTime

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user  User  @relation(fields: [userId], references: [userId])
  event Event @relation(fields: [eventId], references: [eventId])

  payment Payment? @relation(fields: [paymentId], references: [paymentId])

  tickets Ticket[]
  review  Review?

  @@map("orders")
}

model Payment {
  paymentId String @id @default(uuid())

  paymentProof  String?
  paymentStatus PaymentStatus

  paymentAt DateTime?
  expiresAt DateTime

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  order Order?

  @@map("payments")
}

model Event {
  eventId     String @id @default(uuid())
  organizerId String

  title       String
  description String?

  availableSlot Int
  thumbnailUrl  String?

  locationName String
  address      String
  city         String

  slug String

  eventDate        DateTime
  startSellingDate DateTime
  endSellingDate   DateTime

  isFree Boolean
  price  Decimal

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organizer User @relation("OrganizerEvents", fields: [organizerId], references: [userId])

  orders     Order[]
  reviews    Review[]
  wishlists  Wishlist[]
  coupons    EventCoupon[]
  categories EventCategory[]

  @@map("events")
}

model EventCoupon {
  couponId   String  @id @default(uuid())
  couponCode String
  eventId    String
  userId     String?

  validFrom      DateTime
  validUntil     DateTime
  discountAmount Decimal

  usedAt    DateTime?
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [eventId])

  @@map("eventCoupons")
}

model EventCategory {
  categoryId   String @id @default(uuid())
  eventId      String
  categoryName String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  event Event @relation(fields: [eventId], references: [eventId])

  @@map("eventCategories")
}

model Review {
  reviewId    String    @id @default(uuid())
  orderId     String    @unique
  eventId     String
  userId      String
  rating      Int // 1 - 5
  description String?
  isAnonymous Boolean
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user  User  @relation(fields: [userId], references: [userId])
  event Event @relation(fields: [eventId], references: [eventId])
  order Order @relation(fields: [orderId], references: [orderId])

  @@map("reviews")
}

model ReferralCoupon {
  referralId     String @id @default(uuid())
  couponCode     String @unique
  userId         String
  referralCodeBy String

  validFrom  DateTime
  validUntil DateTime
  isActive   Boolean

  discountAmount Decimal
  usedAt         DateTime?
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User @relation("UserCoupons", fields: [userId], references: [userId])
  referredBy User @relation("ReferralOwner", fields: [referralCodeBy], references: [userId])

  @@map("referralCoupons")
}

model AppCoupon {
  appCouponId          String @id @default(uuid())
  couponCode           String
  totalCouponAvailable Int

  validFrom      DateTime
  validUntil     DateTime
  discountAmount Decimal

  usedAt    DateTime?
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appCoupons")
}

model OrganizerProfile {
  organizerId String    @id @default(uuid())
  userId      String    @unique
  name        String    @db.VarChar(30)
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // RELATION (1-1)
  user User @relation(fields: [userId], references: [userId])

  @@map("organizerProfiles")
}

model Wishlist {
  id        String    @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // RELATIONS
  user  User  @relation(fields: [userId], references: [userId])
  event Event @relation(fields: [eventId], references: [eventId])

  @@unique([userId, eventId]) // supaya tidak duplicate wishlist
  @@map("wishlist")
}
